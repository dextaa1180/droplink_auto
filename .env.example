TELEGRAM_BOT_TOKEN=123456789:replace_with_botfather_token
DROPLINK_API_KEY=replace_with_droplink_api_key

# Optional
DROPLINK_BASE_URL=https://droplink.co
ALLOWED_USER_IDS=
ALLOWED_CHAT_IDS=
MAX_URLS_PER_MESSAGE=5
REQUEST_TIMEOUT_MS=15000

# Optional TeraBox Pro integration.
# Default contoh memakai xAPIverse TeraBox Pro: POST {"url":"https://1024terabox.com/s/..."}
TERABOX_RESHARE_API_URL=https://xapiverse.com/api/terabox-pro
TERABOX_RESHARE_API_KEY=
TERABOX_RESHARE_API_KEY_HEADER=xAPIverse-Key
TERABOX_RESHARE_REQUIRE_SESSION=false

# Optional private TeraBox dashboard/session integration.
# Dashboard hanya tersedia di private chat. Kosong berarti mengikuti ALLOWED_USER_IDS.
TERABOX_DASHBOARD_USER_IDS=
TERABOX_SESSION_START_API_URL=
TERABOX_SESSION_STATUS_API_URL=
TERABOX_SESSION_DISCONNECT_API_URL=
TERABOX_SESSION_API_KEY=

# Optional local QR login using Puppeteer.
# If TERABOX_SESSION_START_API_URL is empty, "Login TeraBox" uses this local browser flow.
TERABOX_LOGIN_PUPPETEER_ENABLED=true
TERABOX_LOGIN_URL=https://www.terabox.com/login
TERABOX_LOGIN_TIMEOUT_MS=180000
TERABOX_LOGIN_HEADLESS=true
PUPPETEER_EXECUTABLE_PATH=

# Optional TeraBox converter.
TERABOX_CONVERT_DESTINATION_ROOT=/Tuna Bot
TERABOX_CONVERT_SHARE_PASSWORD=
TERABOX_CONVERT_SHARE_PERIOD=0
TERABOX_CONVERT_WAIT_TIMEOUT_MS=30000
DATA_DIR=data
